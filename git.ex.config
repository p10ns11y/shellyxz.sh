# Git delta snippet for verification reviews (lazygit + terminal diffs).
# migrate.sh copies to ~/.config/git/verification when absent.
# Enable: git config --global include.path ~/.config/git/verification
# delta on PATH: ~/.cargo/bin (env.sh path_prepend) or pacman -S git-delta
# Terminal structural diffs: gdf/gdfs aliases (difftastic) in aliases.sh

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    syntax-theme = Dracula

[merge]
    conflictstyle = diff3

[diff]
    tool = delta
