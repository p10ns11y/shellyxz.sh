# path.contract v2 — resolution order within each phase (top = highest which priority)
# Validated: path_contract_apply in core/env.sh + runtime path_contract_verify
# Personal/machine paths: local/path.contract (see local/path.contract.example)

deny:/condabin
deny:.local/share/../bin

phase:environment
prepend:OMARCHY_PATH/bin:omarchy

phase:core
prepend:HOME/bin
prepend:.local/bin
prepend:mise/shims
prepend:.cargo/bin
prepend:.bun/bin

phase:inherit
keep:system

phase:append
